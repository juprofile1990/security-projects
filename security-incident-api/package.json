{
  "name": "security-incident-api",
  "version": "1.0.0",
  "description": "Production-ready Security Incident Management API",
  "main": "src/index.js",
  "scripts": {
    "build": "prisma generate",
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "test": "NODE_ENV=test jest --runInBand --forceExit",
    "seed": "node prisma/seed.js",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e .env.local -- prisma migrate deploy",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "keywords": [
    "secops",
    "incident-management",
    "express",
    "prisma"
  ],
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "jest": "^29.7.0",
    "prisma": "^6.19.3",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "testTimeout": 30000
  }
}
