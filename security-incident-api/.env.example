# PostgreSQL connection string (pooled, e.g. Supabase port 6543 + ?pgbouncer=true)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/security_incidents?schema=public"

# Direct URL for migrations (bypass pooler; Supabase often uses port 5432)
# DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/security_incidents?schema=public"

# Secret for signing JWTs (use a long random string in production)
JWT_SECRET="change-me-to-a-long-random-secret-in-production"

# Server
PORT=3000
NODE_ENV=development

# Optional: browser origin for the Vite dashboard (default CORS is * which allows localhost)
# CORS_ORIGIN=http://localhost:5173
